# Dashboard Web App
#
# Build: docker build -f docker/Dockerfile.dashboard -t goose-dashboard .
# Run:   docker run -p 3001:3001 goose-dashboard

FROM node:20-alpine AS build

WORKDIR /app

COPY dashboard/package*.json ./
RUN npm install

COPY dashboard/public/ ./public/
COPY dashboard/src/ ./src/
RUN npm run build

FROM nginx:alpine

COPY --from=build /app/build /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
